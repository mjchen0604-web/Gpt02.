# Port
PORT=8000

# Auth dir
CHATGPT_LOCAL_HOME=/data

# show request/stream logs
VERBOSE=false

# OAuth client id (modify only if you know what you're doing)
# CHATGPT_LOCAL_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann

# Reasoning controls
CHATGPT_LOCAL_REASONING_EFFORT=medium       # minimal|low|medium|high
CHATGPT_LOCAL_REASONING_SUMMARY=auto        # auto|concise|detailed|none
CHATGPT_LOCAL_REASONING_COMPAT=think-tags   # legacy|o3|think-tags|current
CHATGPT_LOCAL_EXPOSE_REASONING_MODELS=false

# Enable default web search tool
CHATGPT_LOCAL_ENABLE_WEB_SEARCH=false

# Upstream mode
CHATGPT_LOCAL_UPSTREAM=chatgpt-backend
CHATGPT_LOCAL_CODEX_APP_SERVER_URL=ws://127.0.0.1:8787
CHATGPT_LOCAL_SERVICE_TIER=
CHATGPT_LOCAL_CHANNELS_PATH=
CHATMOCK_GATEWAY_ALLOW_ANONYMOUS=false

# Render / codex app-server deployment
CHATMOCK_DATA_DIR=/app/storage
CODEX_HOME=/app/storage/.codex
CHATMOCK_CONTROL_DB_PATH=/app/storage/chatmock-control.db
CHATMOCK_MANAGE_CODEX_APP_SERVER=true
CHATMOCK_AUTO_START_CODEX_APP_SERVER=true
CHATMOCK_DASHBOARD_ALLOW_UPLOAD=true
# CHATMOCK_DASHBOARD_ADMIN_TOKEN=
# CODEX_AUTH_B64=
# CODEX_AUTH_JSON=
# CODEX_AUTH_JSON_FILE=/etc/secrets/auth.json
# CODEX_CONFIG_B64=
# CODEX_CONFIG_TOML=
# CODEX_CONFIG_TOML_FILE=/etc/secrets/config.toml

# Force a specific model name
# CHATGPT_LOCAL_DEBUG_MODEL=gpt-5

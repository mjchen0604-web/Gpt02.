{
  "api_keys": [
    {
      "name": "default",
      "key": "sk-chatmock-gateway-demo",
      "groups": ["default", "fast"],
      "models": ["*"],
      "enabled": true
    }
  ],
  "channels": [
    {
      "id": "chatgpt-default",
      "transport": "chatgpt-backend",
      "auth_label": "default",
      "groups": ["default"],
      "models": [
        "gpt-5",
        "gpt-5-high",
        "gpt-5-medium",
        "gpt-5-low",
        "gpt-5-minimal",
        "gpt-5.1*",
        "gpt-5.2*",
        "gpt-5.3-codex*",
        "gpt-5-codex*",
        "gpt-5.2-codex*",
        "gpt-5.1-codex*",
        "codex-mini*"
      ],
      "priority": 100,
      "weight": 1,
      "enabled": true
    },
    {
      "id": "codex-fast",
      "transport": "codex-app-server",
      "url": "ws://127.0.0.1:8787",
      "groups": ["default", "fast"],
      "models": ["gpt-5.4-fast*", "gpt-5.4*"],
      "priority": 200,
      "weight": 1,
      "enabled": true
    }
  ]
}

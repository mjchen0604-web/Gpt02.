# Single-service new-api + embedded chat

# Render will inject PORT automatically.
# PORT=3000

# Embedded chat listens only inside the container.
CHATCORE_INTERNAL_CHAT_HOST=127.0.0.1
CHATCORE_INTERNAL_CHAT_PORT=1455

# Optional chat routing defaults.
CHATGPT_LOCAL_ROUTING_STRATEGY=round-robin
CHATGPT_LOCAL_REQUEST_RETRY=0
CHATGPT_LOCAL_MAX_RETRY_INTERVAL=5
# Ordinary requests stay on chatgpt-backend; fast/flex requests auto-switch to codex-app-server.
CHATGPT_LOCAL_UPSTREAM=auto
CHATGPT_LOCAL_CODEX_APP_SERVER_URL=ws://127.0.0.1:8787
CHATMOCK_MANAGE_CODEX_APP_SERVER=1
CHATMOCK_AUTO_START_CODEX_APP_SERVER=1

# Provide ChatMock auth files with one of the following:
# CHATMOCK_AUTH_JSONS_BASE64=base64_auth_json_1,base64_auth_json_2
# CHATMOCK_AUTH_JSON_1={"accessToken":"..."}
# CHATMOCK_AUTH_B64_1=base64_auth_json
